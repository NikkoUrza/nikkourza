{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/descarga", "dest": "/public/descarga.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/cuenta", "dest": "/public/cuenta.html" },
    { "src": "/admin", "dest": "/public/admin/index.html" },
    { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
